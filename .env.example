APP_NAME="System Bankowosci Internetowej"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Warsaw
APP_URL=http://localhost

APP_LOCALE=pl
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Baza danych (MariaDB / MySQL) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=internet_banking
DB_USERNAME=root
DB_PASSWORD=

# Sterowniki plikowe = zero dodatkowych tabel, projekt startuje od razu.
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# Poczta w trybie log — wiadomości trafiają do storage/logs/laravel.log.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@bank.test"
MAIL_FROM_NAME="${APP_NAME}"

# Próg kwoty przelewu wymagającego akceptacji kierownika (PLN).
BANK_APPROVAL_THRESHOLD=10000
